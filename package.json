{
  "name": "@donaton/ui",
  "version": "2.0.0",
  "description": "Biblioteca de componentes React+TypeScript para Donaton — Atomic Design",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
