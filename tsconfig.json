{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "src",
    "paths": {
      "@atoms/*":     ["atoms/*"],
      "@molecules/*": ["molecules/*"],
      "@organisms/*": ["organisms/*"],
      "@templates/*": ["templates/*"],
      "@pages/*":     ["pages/*"],
      "@types/*":     ["types/*"],
      "@tokens/*":    ["tokens/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}